# Example environment file for local development.
# Copy to `.env` (which is git-ignored) and adjust values for your machine.
# These are NON-SECRET local-dev placeholder defaults matching the
# ${DB_USERNAME:root} / ${DB_PASSWORD:123456} fallbacks already baked into
# src/main/resources/application.properties. Do NOT put real/production
# credentials in this file — override them via real environment variables
# or a secret manager in any non-local environment.

# MySQL datasource credentials (spring.datasource.username / .password)
DB_USERNAME=root
DB_PASSWORD=123456
