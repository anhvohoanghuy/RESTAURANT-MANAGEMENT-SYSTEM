# Example environment file for local development.
# Copy to `.env` (which is git-ignored) and adjust values for your machine.
# These are NON-SECRET local-dev placeholder values. Note that
# spring.datasource.password has NO baked-in fallback (it is ${DB_PASSWORD}
# with no default), so the app fails fast at startup if DB_PASSWORD is unset —
# supply it via this .env for local dev, and via real environment variables or
# a secret manager in any non-local environment. Do NOT put real/production
# credentials in this file.

# MySQL datasource credentials (spring.datasource.username / .password)
DB_USERNAME=root
DB_PASSWORD=123456
